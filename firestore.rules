rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "VEes4vSBh0SqSMOiJC8pxyBLnfj2" || 
        request.auth.uid == "yKGfBIJN7kNM56b5gbFK4UeX9Pp2" ||
        request.auth.uid == "nbj2KwFI4rY2Vjj5wOJ1yXhPjIV2"
      );
    }

    // ── Users ──
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Listings ──
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerUID;
    }

    // ── Service Listings ──
    match /serviceListings/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerUID;
    }

    // ── ISO Posts ──
    match /isoPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.posterUID;
    }

    // ── Show Flyers ──
    match /showFlyers/{flyerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.posterUID;
    }

    // ── Conversations ──
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Connection Requests ──
    match /connectionRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    // ── Reports ──
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── Stats ──
    match /stats/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Master/Promo Codes ──
    match /masterCodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Waitlist ──
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Contact Form ──
    match /contactMessages/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Admin wildcard ──
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}